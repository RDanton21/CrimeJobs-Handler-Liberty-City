# Discord Bot
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=

# AI Provider Keys (kann auch via UI gesetzt werden, hier optional)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Default AI
DEFAULT_AI_PROVIDER=anthropic
DEFAULT_CLAUDE_MODEL=claude-sonnet-4-6
DEFAULT_OPENAI_MODEL=gpt-4o

# Server
HOST=127.0.0.1
PORT=8000

# Admin (HTTP-Basic, optional aber empfohlen)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Public-API fuer das externe Jobs-Dashboard (leer = Public-API deaktiviert)
# JOBS_API_KEY=

# Storage (auskommentiert → nutzt projekt-relative Defaults: data\crime.db, data\images)
# DATABASE_URL=sqlite+aiosqlite:///./data/crime.db
# IMAGE_DIR=./data/images

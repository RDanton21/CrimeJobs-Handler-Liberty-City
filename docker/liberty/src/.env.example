####################################
# Discord
####################################
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXXXX/YYYYYYYYYY
DISCORD_USERNAME=The Accountant
DISCORD_AVATAR_URL=
LIBERTY_EMOJI=🗽


####################################
# Goal / Progress
####################################
GOAL_NETTO_EUR=3000
PROGRESS_BAR_LENGTH=20


####################################
# Twitch – App
####################################
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

####################################
# Twitch – Broadcaster
####################################
TWITCH_BROADCASTER_LOGIN=your_login
TWITCH_BROADCASTER_ID=000000000

####################################
# Twitch – EventSub (HTTP webhook transport only)
####################################
TWITCH_EVENTSUB_SECRET=your_eventsub_secret


####################################
# Ko-fi
####################################
KOFI_VERIFICATION_TOKEN=your_kofi_verification_token
KOFI_FEE_PERCENT=0.05
PAYPAL_FEE_PERCENT=0.0249
PAYPAL_FEE_FIXED=0.35


####################################
# Servers — default loopback (127.0.0.1) to keep APIs off the LAN.
# Set to 0.0.0.0 only behind a reverse proxy with auth/TLS.
####################################
KOFI_LISTEN_HOST=127.0.0.1
KOFI_LISTEN_PORT=8080
DASHBOARD_LISTEN_HOST=127.0.0.1
DASHBOARD_LISTEN_PORT=5000

# Allowed Origin for the OBS overlay (echoed back in CORS headers).
OBS_OVERLAY_ORIGIN=http://127.0.0.1:8080


####################################
# Logging — rotating handler
####################################
LOG_FILE=service.log
LOG_MAX_BYTES=10000000
LOG_BACKUP_COUNT=5


####################################
# Admin Panel (Basic-Auth)
# Mounted on the relay's Flask app under /admin; default bind is
# 127.0.0.1, so plain creds are local-only. If you change the bind,
# put it behind TLS + strong password.
####################################
ADMIN_USER=admin
ADMIN_PASS=change-me-please


####################################
# Leaderboard (case_files.jsonl is written by the relay)
####################################
LEADERBOARD_CACHE_TTL=60


####################################
# Status-Message Behavior
####################################
STATUS_REPOST_TO_BOTTOM=1
STATUS_REPOST_COOLDOWN_SEC=0
# 0 = always repost (always at the bottom)
# 15 = max repost every 15s (rate-limit safe)

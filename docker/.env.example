# =============================================================================
# SEKT6R Bot-Stack — Environment Configuration Template
# =============================================================================
# 1. Kopiere diese Datei zu .env:    cp .env.example .env
# 2. Trage deine echten Werte ein (siehe Kommentare über jedem Feld)
# 3. Speichern, dann: docker compose up -d
#
# WICHTIG: .env NIEMALS committen!  (.gitignore schützt sie)
# =============================================================================

# -----------------------------------------------------------------------------
# HTTPS / Reverse-Proxy
# -----------------------------------------------------------------------------
# HTTPS und Cert-Renewal werden vom EXISTIERENDEN Traefik im root_default-
# Network gemanaged (Cert-Resolver: mytlschallenge). Nichts hier nötig.


# =============================================================================
# Kommandozentrale (Web-Dashboard)
# =============================================================================
KZ_ADMIN_USERNAME=admin
# Starkes Passwort, min 16 Zeichen, Sonderzeichen
KZ_ADMIN_PASSWORD=


# =============================================================================
# Crime Automation (Il Padrino)
# Origin: D:\Crime-Automation\.env
# =============================================================================
# Discord-Bot-Token (Discord Developer Portal → Application → Bot → Token)
CRIME_DISCORD_BOT_TOKEN=
CRIME_DISCORD_GUILD_ID=

# Anthropic Claude API-Key (https://console.anthropic.com)
CRIME_ANTHROPIC_API_KEY=
CRIME_OPENAI_API_KEY=

# Default-Provider und Modelle
CRIME_DEFAULT_AI_PROVIDER=anthropic
CRIME_DEFAULT_CLAUDE_MODEL=claude-sonnet-4-5-20250929
CRIME_DEFAULT_OPENAI_MODEL=gpt-4o

# Admin-Login für https://crime.bots.sektorrp.eu
CRIME_ADMIN_USERNAME=
CRIME_ADMIN_PASSWORD=


# =============================================================================
# Liberty City Donations (Du bist Liberty)
# Origin: D:\V2026_Kofi_Twitch_Script_sanitized\.env
# =============================================================================
# Discord-Webhook für Donations-Posts
LIBERTY_DISCORD_WEBHOOK_URL=
LIBERTY_DISCORD_USERNAME=Liberty City
LIBERTY_DISCORD_AVATAR_URL=
LIBERTY_EMOJI=🗽

# Goal-Setup
LIBERTY_GOAL_NETTO_EUR=100
LIBERTY_PROGRESS_BAR_LENGTH=12

# Twitch (https://dev.twitch.tv/console)
LIBERTY_TWITCH_CLIENT_ID=
LIBERTY_TWITCH_CLIENT_SECRET=
LIBERTY_TWITCH_BROADCASTER_LOGIN=
LIBERTY_TWITCH_BROADCASTER_ID=
LIBERTY_TWITCH_EVENTSUB_SECRET=

# Ko-fi Webhook-Verification (https://ko-fi.com/manage/webhooks)
LIBERTY_KOFI_VERIFICATION_TOKEN=
LIBERTY_KOFI_FEE_PERCENT=5
LIBERTY_PAYPAL_FEE_PERCENT=2.49
LIBERTY_PAYPAL_FEE_FIXED=0.35

# Tebex (https://creator.tebex.io)
LIBERTY_TEBEX_SECRET_KEY=

# OBS-Overlay-CORS (auf deinem Streaming-PC)
# "*" = jeder darf zugreifen (einfach, weniger sicher)
# Oder die exakte URL deines OBS-Browser-Source, z.B. "http://localhost"
LIBERTY_OBS_OVERLAY_ORIGIN=*

# Admin-Login für https://liberty.bots.sektorrp.eu
LIBERTY_ADMIN_USER=
LIBERTY_ADMIN_PASS=

# Optional: Tuning
LIBERTY_LEADERBOARD_CACHE_TTL=60
LIBERTY_STATUS_REPOST_TO_BOTTOM=true
LIBERTY_STATUS_REPOST_COOLDOWN_SEC=300
LIBERTY_LOG_MAX_BYTES=5242880
LIBERTY_LOG_BACKUP_COUNT=3


# =============================================================================
# Whitelist Bot (S6-WLH-Bot)
# Origin: D:\bot\.env
# Externe DB: liegt beim Hoster von sektorrp.eu (Webseiten-DB)
# =============================================================================
WHITELIST_BOT_TOKEN=

# Externe MySQL-DB-Verbindung (vom sektorrp.eu Webspace)
# WICHTIG: dort "Remote MySQL Access" für VPS-IP 72.62.63.148 erlauben
WHITELIST_DB_HOST=
WHITELIST_DB_NAME=
WHITELIST_DB_USER=
WHITELIST_DB_PASS=

# Discord
WHITELIST_GUILD_ID=
WHITELIST_ROLE_ID=


# =============================================================================
# Ticket Bot (RAG mit Claude + Knowledge-Base)
# Origin: D:\Ticket Tool\.env
# =============================================================================
TICKET_DISCORD_TOKEN=
TICKET_ANTHROPIC_API_KEY=

# Discord-Channels & Rollen
TICKET_DISCORD_GUILD_ID=
TICKET_CHANNEL_ID=
TICKET_MOD_ROLE_ID=
TICKET_ACCESS_ROLE_ID=
TICKET_CATEGORY_ID=
TICKET_ARCHIVE_CHANNEL_ID=

# KI-Konfiguration
TICKET_CLAUDE_MODEL=claude-sonnet-4-5-20250929
TICKET_EMBED_MODEL=sentence-transformers/multilingual-e5-small
TICKET_CONFIDENCE_THRESHOLD=0.6
TICKET_MAX_TOKENS=1500
TICKET_TOP_K=5
TICKET_SNIPPET_THRESHOLD=0.3
TICKET_SILENT_MENTIONS=true

# Admin-Login für https://ticket.bots.sektorrp.eu
TICKET_ADMIN_USER=
TICKET_ADMIN_PASSWORD=


# =============================================================================
# Countdown Bot
# Origin: D:\Countdown\.env
# =============================================================================
COUNTDOWN_DISCORD_TOKEN=
